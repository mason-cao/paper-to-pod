GEMINI_API_KEY=your_gemini_key_here
# Required when TTS_MODE=server. Leave unset in hosted deployments where the
# free tier blocks datacenter IPs — set TTS_MODE=browser and put the key in
# VITE_ELEVENLABS_API_KEY on the frontend instead.
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Optional: override model IDs
GEMINI_MODEL=gemini-2.5-flash
# server = backend calls ElevenLabs (works locally).
# browser = frontend calls ElevenLabs directly (use for Railway/Vercel/etc).
TTS_MODE=server
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_ORIGIN_REGEX=

# Optional: override voice IDs (defaults are Adam + Bella)
# ALEX_VOICE_ID=pNInz6obpgDQGcFmaJgB
# SAM_VOICE_ID=hpp4J3VqNfWAUOO0d1Us
